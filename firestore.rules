rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Check if user is in admins collection OR is the specific owner email
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "jaysebuckley@gmail.com" && isEmailVerified())
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Lead Validation
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'businessName', 'phone', 'email', 'message', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.businessName is string && data.businessName.size() >= 2 && data.businessName.size() <= 100
        && data.phone is string && data.phone.size() >= 7 && data.phone.size() <= 20
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 100 && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.message is string && data.message.size() >= 10 && data.message.size() <= 5000
        && data.createdAt == request.time;
    }

    match /leads/{leadId} {
      allow create: if isValidLead(incoming());
      allow read, list, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Only existing admins can add new admins
      allow write: if isAdmin();
    }
  }
}
